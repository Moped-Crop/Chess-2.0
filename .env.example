# Строка подключения PostgreSQL (Railway → Postgres → Connect → Postgres Connection URL)
# Для локальной разработки без БД можно указать memory:// (встроенная база в памяти)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Секрет подписи JWT — любая длинная случайная строка (не публиковать!)
JWT_SECRET=replace-me-with-a-long-random-string

# development | production | test
NODE_ENV=development
