# ===== .env — секреты (скопируйте в файл .env) =====

# Строка подключения PostgreSQL (Railway → Postgres → Connect → Connection URL)
# Для запуска без внешней БД можно указать memory:// (встроенная база в памяти,
# данные живут до перезапуска сервера — удобно попробовать локально)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Секрет подписи JWT — любая длинная случайная строка (не публиковать!)
JWT_SECRET=replace-me-with-a-long-random-string

# ===== .env.server — окружение сервера (отдельный файл!) =====
# NODE_ENV живёт в файле .env.server (не в .env), иначе Vite ломает сборку.
# Содержимое .env.server: одна строка
#   NODE_ENV=development
# На хостинге NODE_ENV=production задаётся переменной окружения платформы.
