# ===== .env — секреты (скопируйте в файл .env) =====

# Строка подключения PostgreSQL (Railway → Postgres → Connect → Connection URL)
# Для запуска без внешней БД можно указать memory:// (встроенная база в памяти,
# данные живут до перезапуска сервера — удобно попробовать локально)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Секрет подписи JWT — любая длинная случайная строка (не публиковать!)
JWT_SECRET=replace-me-with-a-long-random-string

# ----- Почта (Resend HTTP-API, письма подтверждения/восстановления) -----
# Через SMTP письма не шлём: Railway режет SMTP-порты (25/465/587) на всех
# тарифах кроме Pro. Resend шлёт письма обычным HTTPS-запросом.
# RESEND_API_KEY: Resend → API Keys → Create (ключ начинается с re_).
# Нужен подтверждённый в Resend домен; отправитель — адрес на этом домене.
RESEND_API_KEY=re_your_api_key
# Кто в поле «От кого». Кавычки вокруг имени обязательны, email — на
# подтверждённом в Resend домене.
MAIL_FROM="Chess 2 · ASCENT" <noreply@your-domain.com>

# Публичный адрес сайта — из него собираются ссылки в письмах.
# Локально: http://localhost:5173 ; на Railway — выданный домен.
APP_URL=http://localhost:5173

# 32-байтовый ключ (hex, 64 символа) для шифрования секретов 2FA в базе.
# Сгенерировать: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ВАЖНО: одинаковый локально и на Railway — иначе расшифровка 2FA сломается.
TOTP_ENCRYPTION_KEY=replace-me-with-64-hex-chars

# ===== .env.server — окружение сервера (отдельный файл!) =====
# NODE_ENV живёт в файле .env.server (не в .env), иначе Vite ломает сборку.
# Содержимое .env.server: одна строка
#   NODE_ENV=development
# На хостинге NODE_ENV=production задаётся переменной окружения платформы.
